.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Local secrets (WiFi creds, host IPs) — never commit. Use secrets.example.h.
secrets.h
**/secrets.h

# Python venv for the CAD scripts — large (~800 MB), machine-specific.
# Recreate it with 3d-model/setup.sh (deps are pinned in requirements.txt).
3d-model/.venv/
**/__pycache__/

# Generated CAD artifacts — large and regenerable from the .py scripts.
# Ignore every mesh/solid export under 3d-model/ (thistle, cymatics, mandelbulb,
# the "saved models" archive, etc.).
3d-model/**/*.stl
3d-model/**/*.step

# …except the printed-model reference archive: those files ARE the record of
# what was physically printed, kept next to their photos + settings. Commit them.
!3d-model/printed/**/*.stl
!3d-model/printed/**/*.step
